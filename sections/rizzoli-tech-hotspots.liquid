{{ 'rizzoli-base.css' | asset_url | stylesheet_tag }}

<style>
  .rz-tech {
    padding: 100px 40px;
    background: var(--rz-gray-light);
  }

  .rz-tech__container {
    max-width: var(--rz-max-width);
    margin: 0 auto;
  }

  .rz-tech__header {
    text-align: center;
    margin-bottom: 60px;
  }

  .rz-tech__title {
    font-family: var(--rz-font-heading);
    font-size: var(--rz-text-h2);
    font-weight: var(--rz-fw-bold);
    margin-bottom: 12px;
  }

  .rz-tech__subtitle {
    font-family: var(--rz-font-body);
    font-size: var(--rz-text-body-lg);
    color: #555;
  }

  .rz-tech__visual {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .rz-tech__image {
    width: 100%;
    display: block;
  }

  .rz-tech__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Hotspot dot */
  .rz-tech__hotspot {
    position: absolute;
    width: 28px;
    height: 28px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 2;
  }

  .rz-tech__dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--rz-red);
    border: 3px solid var(--rz-white);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    position: relative;
    transition: transform var(--rz-transition);
  }

  .rz-tech__dot::after {
    content: '';
    position: absolute;
    top: -6px;
    left: -6px;
    right: -6px;
    bottom: -6px;
    border-radius: 50%;
    border: 2px solid var(--rz-red);
    opacity: 0;
    animation: rz-pulse 2s infinite;
  }

  @keyframes rz-pulse {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  .rz-tech__hotspot:hover .rz-tech__dot {
    transform: scale(1.2);
  }

  /* Tooltip card */
  .rz-tech__tooltip {
    position: absolute;
    bottom: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--rz-white);
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    padding: 16px 20px;
    min-width: 220px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--rz-transition), visibility var(--rz-transition);
    pointer-events: none;
    z-index: 10;
  }

  .rz-tech__tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 8px solid transparent;
    border-top-color: var(--rz-white);
  }

  .rz-tech__hotspot:hover .rz-tech__tooltip,
  .rz-tech__hotspot.rz-active .rz-tech__tooltip {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .rz-tech__tooltip-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 8px;
  }

  .rz-tech__tooltip-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .rz-tech__tooltip-name {
    font-family: var(--rz-font-heading);
    font-size: var(--rz-text-h5);
    font-weight: var(--rz-fw-bold);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    color: var(--rz-black);
  }

  .rz-tech__tooltip-desc {
    font-family: var(--rz-font-body);
    font-size: var(--rz-text-body-sm);
    color: #666;
    line-height: 1.5;
  }

  /* Hotspot positions — set via block settings */
  {% for block in section.blocks %}
    .rz-tech__hotspot--{{ forloop.index }} {
      top: {{ block.settings.position_y }}%;
      left: {{ block.settings.position_x }}%;
    }

    /* Tooltip repositioning for edge hotspots */
    {% if block.settings.position_x > 70 %}
      .rz-tech__hotspot--{{ forloop.index }} .rz-tech__tooltip {
        left: auto;
        right: 0;
        transform: none;
      }
      .rz-tech__hotspot--{{ forloop.index }} .rz-tech__tooltip::after {
        left: auto;
        right: 20px;
        transform: none;
      }
    {% elsif block.settings.position_x < 30 %}
      .rz-tech__hotspot--{{ forloop.index }} .rz-tech__tooltip {
        left: 0;
        transform: none;
      }
      .rz-tech__hotspot--{{ forloop.index }} .rz-tech__tooltip::after {
        left: 20px;
        transform: none;
      }
    {% endif %}
  {% endfor %}

  /* Mobile: list view instead of hotspots */
  @media (max-width: 768px) {
    .rz-tech {
      padding: 60px 20px;
    }

    .rz-tech__visual {
      margin-bottom: 40px;
    }

    .rz-tech__hotspot {
      display: none;
    }

    .rz-tech__list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .rz-tech__list-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 20px;
      background: var(--rz-white);
      border-radius: 4px;
    }

    .rz-tech__list-icon {
      width: 48px;
      height: 48px;
      margin-bottom: 12px;
    }

    .rz-tech__list-icon img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .rz-tech__list-name {
      font-family: var(--rz-font-heading);
      font-size: var(--rz-text-caption);
      font-weight: var(--rz-fw-bold);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
    }

    .rz-tech__list-desc {
      font-family: var(--rz-font-body);
      font-size: var(--rz-text-body-sm);
      color: #666;
      line-height: 1.4;
    }
  }

  @media (min-width: 769px) {
    .rz-tech__list {
      display: none;
    }
  }
</style>

<section class="rz-tech" data-section-id="{{ section.id }}">
  <div class="rz-tech__container">
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="rz-tech__header rz-fade-in">
        {%- if section.settings.title != blank -%}
          <h2 class="rz-tech__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="rz-tech__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="rz-tech__visual rz-fade-in">
      <div class="rz-tech__image">
        {%- if section.settings.product_image != blank -%}
          <img
            src="{{ section.settings.product_image | image_url: width: 1200 }}"
            alt="{{ section.settings.title | escape }}"
            loading="lazy"
            width="1200"
            height="800"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        <div class="rz-tech__hotspot rz-tech__hotspot--{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="rz-tech__dot"></div>
          <div class="rz-tech__tooltip">
            {%- if block.settings.icon != blank -%}
              <div class="rz-tech__tooltip-icon">
                <img src="{{ block.settings.icon | image_url: width: 80 }}" alt="{{ block.settings.name | escape }}">
              </div>
            {%- endif -%}
            <div class="rz-tech__tooltip-name">{{ block.settings.name }}</div>
            <div class="rz-tech__tooltip-desc">{{ block.settings.description }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Mobile: list fallback {%- endcomment -%}
    <div class="rz-tech__list">
      {%- for block in section.blocks -%}
        <div class="rz-tech__list-item">
          {%- if block.settings.icon != blank -%}
            <div class="rz-tech__list-icon">
              <img src="{{ block.settings.icon | image_url: width: 96 }}" alt="{{ block.settings.name | escape }}">
            </div>
          {%- endif -%}
          <div class="rz-tech__list-name">{{ block.settings.name }}</div>
          <div class="rz-tech__list-desc">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  /* Touch support for hotspots on tablet */
  document.addEventListener('DOMContentLoaded', function() {
    var hotspots = document.querySelectorAll('.rz-tech__hotspot');
    hotspots.forEach(function(hotspot) {
      hotspot.addEventListener('click', function(e) {
        var wasActive = this.classList.contains('rz-active');
        hotspots.forEach(function(h) { h.classList.remove('rz-active'); });
        if (!wasActive) {
          this.classList.add('rz-active');
        }
      });
    });

    document.addEventListener('click', function(e) {
      if (!e.target.closest('.rz-tech__hotspot')) {
        hotspots.forEach(function(h) { h.classList.remove('rz-active'); });
      }
    });
  });
</script>

{% schema %}
{
  "name": "RIZZOLI Tecnologías",
  "tag": "section",
  "class": "rz-tech-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Tecnología que protege"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Ingeniería de protección en cada detalle"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto",
      "info": "Foto grande del zapato sobre la cual se posicionan los hotspots. Recomendado: 1200x800px"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Tecnología",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nombre de la tecnología",
          "default": "Punta Composite"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Protección de impacto con material composite ultraligero, visualmente imperceptible."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Logo/icono de la tecnología",
          "info": "Sube el icono o logo de esta tecnología. Recomendado: 80x80px PNG"
        },
        {
          "type": "range",
          "id": "position_x",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Posición horizontal (izq → der)",
          "default": 50
        },
        {
          "type": "range",
          "id": "position_y",
          "min": 5,
          "max": 95,
          "step": 1,
          "unit": "%",
          "label": "Posición vertical (arriba → abajo)",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RIZZOLI Tecnologías",
      "blocks": [
        { "type": "hotspot", "settings": { "name": "Punta Composite", "position_x": 25, "position_y": 40 } },
        { "type": "hotspot", "settings": { "name": "Suela Antideslizante", "position_x": 50, "position_y": 85 } },
        { "type": "hotspot", "settings": { "name": "Membrana Impermeable", "position_x": 60, "position_y": 35 } },
        { "type": "hotspot", "settings": { "name": "Plantilla Ergonómica", "position_x": 40, "position_y": 70 } }
      ]
    }
  ]
}
{% endschema %}
