{{ 'rizzoli-base.css' | asset_url | stylesheet_tag }}

<style>
  .rz-categories {
    padding: 80px 40px;
    max-width: var(--rz-max-width);
    margin: 0 auto;
  }

  .rz-categories__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .rz-categories__card {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    border: 0.5px solid var(--rz-gray);
    border-radius: 2px;
    display: block;
    text-decoration: none;
  }

  .rz-categories__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .rz-categories__card:hover img {
    transform: scale(1.05);
  }

  .rz-categories__overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    transition: background var(--rz-transition);
  }

  .rz-categories__card:hover .rz-categories__overlay {
    background: rgba(0, 0, 0, 0.55);
  }

  .rz-categories__title {
    color: var(--rz-white);
    font-family: var(--rz-font-heading);
    font-size: var(--rz-text-h2);
    font-weight: var(--rz-fw-bold);
    letter-spacing: 0.02em;
    transition: transform var(--rz-transition);
  }

  .rz-categories__card:hover .rz-categories__title {
    transform: translateY(-5px);
  }

  .rz-categories__btn {
    display: inline-block;
    background: var(--rz-white);
    color: var(--rz-black);
    font-family: var(--rz-font-heading);
    font-size: var(--rz-text-button);
    font-weight: var(--rz-fw-black);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 23px;
    border-radius: 2px;
    margin-top: 14px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity var(--rz-transition), transform var(--rz-transition);
  }

  .rz-categories__card:hover .rz-categories__btn {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .rz-categories {
      padding: 60px 20px;
    }

    .rz-categories__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .rz-categories__card {
      aspect-ratio: 16/9;
    }
  }
</style>

<section class="rz-categories" data-section-id="{{ section.id }}">
  <div class="rz-categories__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="rz-categories__card rz-fade-in" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.title | escape }}"
            loading="lazy"
            width="800"
            height="600"
          >
        {%- else -%}
          {{ 'collection-' | append: forloop.index | placeholder_svg_tag }}
        {%- endif -%}

        <div class="rz-categories__overlay">
          <h2 class="rz-categories__title">{{ block.settings.title }}</h2>
          <span class="rz-categories__btn">VER MÁS</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "RIZZOLI Categorías",
  "tag": "section",
  "class": "rz-categories-section",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de categoría",
          "info": "Recomendado: 800x600px"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre de categoría",
          "default": "Categoría"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link de categoría"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RIZZOLI Categorías",
      "blocks": [
        { "type": "category", "settings": { "title": "Hombre" } },
        { "type": "category", "settings": { "title": "Mujer" } },
        { "type": "category", "settings": { "title": "Accesorios" } }
      ]
    }
  ]
}
{% endschema %}
