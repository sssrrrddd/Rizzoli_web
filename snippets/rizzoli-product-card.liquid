{%- comment -%}
  RIZZOLI Product Card Snippet
  Accepts:
    - product: {Object} Shopify product object
    - show_badge: {Boolean} Show "NUEVO" badge
    - badge_text: {String} Custom badge text
    - lazy: {Boolean} Lazy load image (default true)
{%- endcomment -%}

{%- liquid
  assign show_badge = show_badge | default: false
  assign badge_text = badge_text | default: 'NUEVO'
  assign lazy = lazy | default: true
-%}

<article class="rz-product-card">
  <a href="{{ product.url }}" class="rz-product-card__link" aria-label="{{ product.title }}">
    <div class="rz-product-card__img-wrapper">
      {%- if show_badge -%}
        <span class="rz-product-card__badge">{{ badge_text }}</span>
      {%- endif -%}

      {%- if product.featured_image != blank -%}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.title | escape }}"
          {% if lazy %}loading="lazy"{% endif %}
          width="600"
          height="600"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    <div class="rz-product-card__name-row">
      <h3 class="rz-product-card__name">{{ product.title }}</h3>
      {%- if product.variants.size > 1 -%}
        <div class="rz-product-card__color-dot" aria-label="Variantes disponibles"></div>
      {%- endif -%}
    </div>

    {%- if product.description != blank -%}
      <p class="rz-product-card__desc">{{ product.description | strip_html | truncate: 60 }}</p>
    {%- endif -%}

    <p class="rz-product-card__price">{{ product.price | money }}</p>
  </a>
</article>
